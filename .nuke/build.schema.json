{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "ConfigurationValidate",
        "DetermineBuildConfig",
        "DockerLogin",
        "Download",
        "GitHubRelease",
        "PushToAliyunAcr",
        "PushToAzureAcr",
        "PushToDockerHub",
        "VersionMonitor"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "AliyunAcrNamespace": {
          "type": "string",
          "description": "Aliyun ACR namespace"
        },
        "AliyunAcrPassword": {
          "type": "string",
          "description": "Aliyun ACR password"
        },
        "AliyunAcrRegistry": {
          "type": "string",
          "description": "Aliyun ACR registry endpoint"
        },
        "AliyunAcrUsername": {
          "type": "string",
          "description": "Aliyun ACR username"
        },
        "AzureAcrNamespace": {
          "type": "string",
          "description": "Azure ACR namespace"
        },
        "AzureAcrPassword": {
          "type": "string",
          "description": "Azure ACR password"
        },
        "AzureAcrRegistry": {
          "type": "string",
          "description": "Azure ACR registry endpoint"
        },
        "AzureAcrUsername": {
          "type": "string",
          "description": "Azure ACR username"
        },
        "AzureBlobSasUrl": {
          "type": "string",
          "description": "Azure Blob Storage SAS URL for downloading packages"
        },
        "DockerBuildTimeout": {
          "type": "integer",
          "description": "Docker build timeout in seconds (default: 3600)",
          "format": "int32"
        },
        "DockerForceRebuild": {
          "type": "boolean",
          "description": "Force rebuild of Docker images"
        },
        "DockerHubNamespace": {
          "type": "string",
          "description": "DockerHub namespace"
        },
        "DockerHubToken": {
          "type": "string",
          "description": "DockerHub access token"
        },
        "DockerHubUsername": {
          "type": "string",
          "description": "DockerHub username"
        },
        "DockerImageName": {
          "type": "string",
          "description": "Docker image name (e.g., hagicode/hagicode)"
        },
        "DockerPlatform": {
          "type": "string",
          "description": "Docker platform: linux-amd64, linux-arm64, or all (default: all)"
        },
        "DryRun": {
          "type": "string",
          "description": "Dry run mode (do not trigger actual releases)"
        },
        "EnableIndependentBuild": {
          "type": "string",
          "description": "Enable independent build and push to registries (instead of export/import)"
        },
        "FeishuWebhookUrl": {
          "type": "string",
          "description": "Feishu webhook URL for notifications"
        },
        "GitHubRepository": {
          "type": "string",
          "description": "GitHub repository (e.g., owner/repo)"
        },
        "GitHubToken": {
          "type": "string",
          "description": "GitHub token for release creation"
        },
        "ListOnly": {
          "type": "string",
          "description": "List only mode (do not trigger releases, just output versions)"
        },
        "OutputDirectory": {
          "type": "string",
          "description": "Output directory for downloaded/extracted files"
        },
        "ReleaseVersion": {
          "type": "string",
          "description": "Version to create GitHub release for"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
