# Local Docker build inputs
# Keep plaintext secrets in .env.secrets.local so this file can stay shareable.
HAGICODE_RELEASE_VERSION=
HAGICODE_LOCAL_IMAGE=
HAGICODE_LOCAL_CONTAINER_NAME=hagicode-local
HAGICODE_DOCKER_PLATFORM=
AZURE_BLOB_SAS_URL=

# Local compose networking
HAGICODE_HTTP_BIND=127.0.0.1
HAGICODE_HTTP_PORT=5000
HAGICODE_CODE_SERVER_BIND=127.0.0.1
VSCODE_SERVER_PORT=36529
VSCODE_SERVER_HOST=0.0.0.0
VSCODE_SERVER_AUTH_MODE=none

# Runtime defaults
ACCEPT_EULA=Y
ASPNETCORE_ENVIRONMENT=Development
CLAUDE_HOST_CONFIG_ENABLED=false
OMNIROUTE_ENABLE_BOOTSTRAP=true
PUID=1000
PGID=1000

# Optional provider wiring
ANTHROPIC_URL=
ANTHROPIC_AUTH_TOKEN=
CODEX_BASE_URL=
CODEX_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENCODE_BASE_URL=
OPENCODE_API_BASE_URL=
OPENCODE_API_KEY=

# Optional code-server password mode
CODE_SERVER_PASSWORD=
CODE_SERVER_HASHED_PASSWORD=

# Optional SSH bootstrap
SSH_PRIVATE_KEY_PATH=
SSH_KNOWN_HOSTS_PATH=
SSH_STRICT_HOST_KEY_CHECKING=accept-new
