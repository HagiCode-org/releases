# HagiCode Unified Docker Image
# Multi-stage build combining base tools and application code
#
# CLI Tools Baseline:
# - HagiScript bootstrap: 0.1.0 (@hagicode/hagiscript@0.1.0)
# - HagiScript npm-sync manifest: docker_deployment/hagiscript-sync-manifest.json
# - Optional agent CLI IDs: claude-code, fission-openspec, opencode, codex
# - Mandatory HagiScript tool sync: skills, omniroute, code-server
# - pm2: 6.0.14 (pm2@6.0.14)
#
# FRAMEWORK-DEPENDENT DEPLOYMENT:
# This unified Dockerfile provides .NET 10 runtime in the base stage.
# The application packages do NOT include runtime to reduce size.
#
# Template variables: __HAGICODE_VERSION__, __HAGICODE_BUILD_DATE__

# ============================================================================
# Base Stage (internal, not pushed as independent image)
# ============================================================================
FROM debian:bookworm-slim AS base

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Metadata labels
LABEL description="HagiCode Base - Debian Bookworm slim, Node.js 22 via NVM, .NET 10 runtime with CLI tools"
LABEL maintainer="HagiCode Contributors"
LABEL purpose="Base stage for unified multi-stage build"

# Install runtime dependencies needed by the app, non-root startup, and SSH/Git access.
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    gosu \
    git \
    libicu72 \
    openssh-client \
    wget \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Install .NET 10 ASP.NET Core Runtime using official Microsoft script
# This runtime is REQUIRED for framework-dependent deployments
# The application packages do NOT include runtime to reduce size
RUN wget -qO- https://dot.net/v1/dotnet-install.sh | bash /dev/stdin \
    --channel 10.0 \
    --runtime aspnetcore \
    --install-dir /usr/share/dotnet \
    --version latest

# Add .NET and Node.js environment configuration
ENV DOTNET_ROOT=/usr/share/dotnet \
    NVM_DIR=/usr/local/nvm \
    NVM_SYMLINK_CURRENT=true \
    NODE_VERSION=22 \
    HOME=/home/hagicode \
    NPM_CONFIG_PREFIX=/home/hagicode/.npm-global \
    HAGISCRIPT_NPM_SYNC_MANIFEST=/app/bootstrap/hagiscript-sync-manifest.json \
    HAGISCRIPT_MANAGED_RUNTIME=/home/hagicode/.hagiscript/node-runtime \
    PINNED_HAGISCRIPT_VERSION=0.1.0
ENV PATH="/home/hagicode/.npm-global/bin:/home/hagicode/.hagiscript/node-runtime/bin:/usr/local/nvm/current/bin:${DOTNET_ROOT}:${PATH}"

# Install Node.js 22 through a shared, image-managed NVM layout and expose it on PATH
# Clear the npm prefix only for the bootstrap layer so nvm install can run cleanly.
RUN mkdir -p "$NVM_DIR" && \
    export PROFILE=/dev/null && \
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash && \
    unset NPM_CONFIG_PREFIX && \
    source "$NVM_DIR/nvm.sh" && \
    nvm install "${NODE_VERSION}" && \
    nvm alias default "${NODE_VERSION}" && \
    nvm use default >/dev/null && \
    NODE_BIN_DIR="$(dirname "$(nvm which default)")" && \
    ln -sf "${NODE_BIN_DIR}/node" /usr/local/bin/node && \
    ln -sf "${NODE_BIN_DIR}/npm" /usr/local/bin/npm && \
    ln -sf "${NODE_BIN_DIR}/npx" /usr/local/bin/npx && \
    ln -sf "${NODE_BIN_DIR}/corepack" /usr/local/bin/corepack && \
    node --version && \
    npm --version && \
    npx --version

# Create non-root user for running the application
# Claude Code CLI cannot run as root user
# Use UID 1000 to match common host user UID
# -o allows groupadd/useradd to succeed even if GID/UID already exists
RUN groupadd -o -g 1000 hagicode && \
    useradd -o -u 1000 -g 1000 -s /bin/bash -m hagicode && \
    mkdir -p /home/hagicode/.claude /home/hagicode/.npm-global /home/hagicode/.hagiscript && \
    chown -R hagicode:hagicode /home/hagicode

# Switch to hagicode user for npm installations
USER hagicode
WORKDIR /home/hagicode

# Configure npm to install global packages in user's home directory
RUN npm config set prefix '/home/hagicode/.npm-global'

# Copy the release-owned HagiScript sync input before running the build-time tool sync.
COPY --chown=hagicode:hagicode hagiscript-sync-manifest.json /app/bootstrap/hagiscript-sync-manifest.json

# Install pinned HagiScript first, then delegate the retained baked toolchain to npm-sync.
RUN npm install -g "@hagicode/hagiscript@${PINNED_HAGISCRIPT_VERSION}" && \
    hagiscript --version && \
    hagiscript npm-sync \
        --managed-runtime "${HAGISCRIPT_MANAGED_RUNTIME}" \
        --manifest "${HAGISCRIPT_NPM_SYNC_MANIFEST}" && \
    claude --version && \
    openspec --version && \
    skills --version && \
    opencode --version && \
    codex --version && \
    omniroute --help >/dev/null && \
    pm2 --version && \
    command -v pm2-runtime >/dev/null && \
    code-server --version && \
    npm cache clean --force

# Switch back to root for final setup
USER root
WORKDIR /app

# Clean up npm global cache to reduce image size
RUN rm -rf /home/hagicode/.npm/_logs /tmp/*

# Clean up temporary files to reduce image size
RUN rm -rf /var/tmp/* /tmp/* /var/cache/* /var/log/*

# ============================================================================
# Final Stage (pushed as hagicode:__HAGICODE_VERSION__)
# ============================================================================
FROM base AS final

ARG version
ARG build_date
ARG TARGETARCH

# Metadata labels
LABEL version="__HAGICODE_VERSION__"
LABEL build.date="__HAGICODE_BUILD_DATE__"
LABEL description="HagiCode - AI-assisted development platform (framework-dependent deployment)"
LABEL deployment.type="framework-dependent"

# Set environment variables for application
ENV ASPNETCORE_ENVIRONMENT=Production
ENV ASPNETCORE_URLS=http://+:5000

# Copy entrypoint script that configures Claude Code settings
COPY --chown=hagicode:hagicode docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Copy shared process supervision artifacts used by the Omniroute-first startup contract
COPY --chown=hagicode:hagicode ecosystem.config.cjs /app/bootstrap/ecosystem.config.cjs
COPY --chown=hagicode:hagicode omniroute-bootstrap.mjs /app/bootstrap/omniroute-bootstrap.mjs
COPY --chown=hagicode:hagicode wait-for-ready.sh /app/bootstrap/wait-for-ready.sh
RUN chmod +x /app/bootstrap/wait-for-ready.sh

# Copy application structure from Linux platform package
# Framework-dependent package structure:
# - lib/        : Application binaries and dependencies (NO runtime)
# - *.sh        : Startup scripts
# - config/     : Configuration files
#
# The .NET runtime is provided by the base stage at:
# - /usr/share/dotnet/dotnet (executable)
# - Shared libraries in /usr/share/dotnet/shared/
COPY "lib-${TARGETARCH}/" /app/

# Set ownership for application directory
RUN chown -R hagicode:hagicode /app

# Create directories for system-scoped and save-scoped application data
RUN mkdir -p /app/data /app/data/omniroute /app/data/omniroute/pm2 /app/data/omniroute/runtime /app/saves && \
    chown -R hagicode:hagicode /app

# Expose the application port (default 5000)
EXPOSE 5000

# Add health check
# The application should respond to HTTP requests on port 5000
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 CMD curl -f http://localhost:5000/ || exit 1

# Set working directory to /app where the application resides
WORKDIR /app

# Run entrypoint script which configures Omniroute, CLI routing, and pm2-managed startup
ENTRYPOINT ["docker-entrypoint.sh"]
